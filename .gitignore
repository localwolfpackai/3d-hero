# Environment
# - Always ignore secrets
.env
.env.local
.env.*.local

# If you use Vite/Next/etc, you might generate local overrides.
# Keep this broad ignore, but still allow the explicit env patterns above.
*.local

# (Optional) ignore other env variants people sometimes create
.env.*

# Dependencies
node_modules/

# Build
dist/
.next/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
